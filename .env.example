# Local, non-git workspace for official source files and generated SQLite output.
# Do not point these at the Git repository itself.
SWISS_AMBULATORY_GROUPER_DATA_DIR=/absolute/path/to/local/non-git-data/swiss-ambulatory-grouper-mcp
SWISS_AMBULATORY_GROUPER_SOURCE_DIR=/absolute/path/to/local/non-git-data/swiss-ambulatory-grouper-mcp/sources
SWISS_AMBULATORY_GROUPER_OUTPUT_DIR=/absolute/path/to/local/non-git-data/swiss-ambulatory-grouper-mcp/output

# Optional catalogue/application year used by scripts.
SWISS_AMBULATORY_GROUPER_YEAR=2027

# Optional: use ICD/CIM files from a different BFS year, e.g. tariff 2027 with ICD/CIM 2026.
SWISS_AMBULATORY_GROUPER_ICD_YEAR=2026
